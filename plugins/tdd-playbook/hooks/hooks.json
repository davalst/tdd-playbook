{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/test_lock_guard.py\"",
            "timeout": 15,
            "statusMessage": "TDD: test-lock guard"
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/snapshot_guard.py\"",
            "timeout": 15,
            "statusMessage": "TDD: snapshot guard"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/snapshot_guard.py\"",
            "timeout": 15,
            "statusMessage": "TDD: snapshot guard"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/test_weakening_guard.py\"",
            "timeout": 15,
            "statusMessage": "TDD: test-weakening guard"
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/flaky_guard.py\"",
            "timeout": 15,
            "statusMessage": "TDD: flaky-pattern guard"
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/overmock_guard.py\"",
            "timeout": 15,
            "statusMessage": "TDD: over-mock guard"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/intent_nudge.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/build_completion_reminder.py\"",
            "timeout": 15,
            "statusMessage": "TDD: Tripwire reminder"
          }
        ]
      }
    ]
  }
}
